# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Production URL for password reset email links. Falls back to window.location.origin if not set.
VITE_PASSWORD_RESET_REDIRECT_URL=https://your-production-domain.com/?page=reset-password

# OpenAI API Key (if needed)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase Access Token (for deployment scripts)
# Get this from: https://app.supabase.com/account/tokens
# SUPABASE_ACCESS_TOKEN=your_access_token
